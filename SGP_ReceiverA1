Logger::Logger(RTCManager &rtcMgr, RTC_DS3231 &rtc, Adafruit_INA219 &ina, Adafruit_AHTX0 &aht,
               Adafruit_seesaw &ssw, Adafruit_BME280 &bme) : rtcManager(rtcMgr),
                                                             rtc(rtc),
                                                             ina(ina),
                                                             aht(aht),
                                                             ssw(ssw),
                                                             bme(bme) {}

//
void Logger::begin(bool &ahtOK, bool &sswOK, bool &inaOK, bool &bmeOK) {
    
  // Transmits permission for secondary nodes to collect and transmit back data.
  giveGoSignal();

  // The LoRa module is set to receive and log P2P sensor data from other nodes.
  //logLoRaMessages();

  //
  logSensorData(ahtOK, bmeOK, sswOK, inaOK);

  // The ESP32 is put into deep sleep and I2C/SPI buses are disabled.
  rtcManager.goToSleep();
}

// This method will transmit a signal secondary nodes require to collect and transmit data.
void Logger::giveGoSignal() {

  // Flushes Serial1 input.
  while (Serial1.available()) {
    Serial1.read();
    delay(1);
  }

  // Puts the LoRa module into transmit/receieve mode.
  Serial1.println(F("AT+MODE=0"));
  delay(100);

  // Verifies that the LoRa module is functioning.
  while (Serial1.available()) {
    String response = Serial1.readStringUntil('\n');
    response.trim();
    Serial.println("LoRa Response: " + response);
  }

  // Transmits the GO signal.
  Serial1.println(F("GO"));
  Serial.println(F("Primary node permission transmitted."));
  unsigned long goStart = millis();
  while (!Serial1.available() && millis() - goStart < 1000);

  // Declares the start time of the current log cycle.
  DateTime now = rtc.now();
  Serial.print(F("Log cycle started at: "));
  Serial.println(now.timestamp(DateTime::TIMESTAMP_FULL));
}

// This method will collect and log all local sensor data.
void Logger::logSensorData(bool &ahtOK, bool &bmeOK, bool &sswOK, bool &inaOK) {

  // Verifies the functionality of all local sensors.
  if (!ahtOK && !bmeOK && !sswOK) {
    
    // Logs initialization failure of all local sensors.
    String initFailLine = String(DEVICE_NAME) + "," + formattedTime(rtc.now()) +
                      ",SENSORS_INIT_FAIL,SKIPPING_DATA_LOG";
    appendFile(SD, DATA_LOG, initFailLine.c_str());
    Serial.println(F("Local data log skipped due to complete sensor failure."));
  } else {

    // Will collect AHT21 data if it's present.
    sensors_event_t humdAHT, tempAHT;
    if (ahtOK) {
      if (!aht.getEvent(&humdAHT, &tempAHT)) {
        Serial.println(F("AHT21 sensor read failed."));
        ahtOK = false;
      }

      // Puts the AHT21 to sleep.
      sleepAHT21();
    }

    // Will collect BME280 data if it's present.
    // If both the AHT21 and BME280 are present, an average is taken for temperature and humidity.
    float tempAVG = NAN, humdAVG = NAN, presAVG = NAN;
    if (bmeOK) {
      if (bme.takeForcedMeasurement()) {
        float tempBME = bme.readTemperature();
        float humdBME  = bme.readHumidity();
        float presBME = bme.readPressure();

        tempAVG = ahtOK ? round((tempAHT.temperature + tempBME) / 2.0) : round(tempBME);
        humdAVG = ahtOK ? round((humdAHT.relative_humidity + humdBME) / 2.0) : round(humdBME);
        presAVG = round(presBME / 100.0); // convert to hPa
      } else {
        Serial.println(F("BME280 forced measurment failed."));
        bmeOK = false;
      }
    } else if (ahtOK) {
      tempAVG = round(tempAHT.temperature);
      humdAVG = round(humdAHT.relative_humidity);
    }

    // Will collect STEMMA Seesaw data if it's present.
    float tempSSW = NAN;
    float rawSSW  = ssw.getTemp();
    Wire.beginTransmission(0x36);
    if (Wire.endTransmission() != 0) {
      Serial.println(F("STEMMA Seesaw is not responding."));
      sswOK = false;
    } else if (isnan(rawSSW)) {
      Serial.println(F("STEMMA Seesaw read failed."));
      sswOK = false;
    } else {
      tempSSW = round(rawSSW);
    }
    ssw.SWReset();

    // Verifies the functionality of all local sensors.
    if (!ahtOK && !bmeOK && !sswOK) {

      // Logs read failure of all local sensors.
      String readFailLine = String(DEVICE_NAME) + "," + formattedTime(rtc.now()) +
                        ",SENSORS_READ_FAIL,SKIPPING_DATA_LOG";
      appendFile(SD, DATA_LOG, readFailLine.c_str());
      Serial.println(F("Local data log skipped due to complete sensor failure."));
      return;
    }

    // Will collect INA219 data if it's present.
    float voltINA = NAN, currINA = NAN;
    if (inaOK) {
      voltINA = ina.getBusVoltage_V();
      currINA = ina.getCurrent_mA();
      if (isnan(voltINA) || isnan(currINA)) {
        Serial.println(F("INA219 sensor read failed."));
      } else {
        ina.powerSave(true); // puts INA219 to sleep
      }
    }

    // Creates a CSV line of sensor data.
    DateTime now = rtc.now();
    String dataLine = String(DEVICE_NAME) + "," + formattedTime(now) + "," +
                  (isnan(tempAVG) ? "NA" : String((int)tempAVG)) + "," +
                  (isnan(humdAVG) ? "NA" : String((int)humdAVG)) + "," +
                  (isnan(presAVG) ? "NA" : String(presAVG)) + "," +
                  (isnan(tempSSW) ? "NA" : String((int)tempSSW)) + "," +
                  (isnan(voltINA) ? "NA" : String(voltINA, 2)) + "," +
                  (isnan(currINA) ? "NA" : String(currINA, 2));

    // Appends the given data line to the existing data log.
    appendFile(SD, DATA_LOG, dataLine.c_str());
  }
}

// This method disables the AHT21 via I2C to emulate sleep mode.
// This is a sub-method of the logSensorData method.
void Logger::sleepAHT21() {
  Wire.beginTransmission(0x38);
  Wire.write(0xB0);
  Wire.endTransmission();
}

// This method formats the current time into CSV.
// This is a sub-method of the logSensorData method.
String Logger::formattedTime(DateTime now) {
  return String(now.month()) + "/" + String(now.day()) + "/" + String(now.year()) + "," +
        (now.hour() < 10 ? "0" : "") + String(now.hour()) + ":" +
        (now.minute() < 10 ? "0" : "") + String(now.minute());
}

// This method opens and appends a given line of data to the data log.
// This is a sub-method of the logSensorData method.
void Logger::appendFile(fs::FS &fs, const char *path, const char *message) {
  File file = fs.open(path, FILE_APPEND);
  if (!file) {
    Serial.println("Failed to open file for appending");
    return;
  }
  file.println(message);
  file.flush();
  file.close();
}

// This method will receive and log sensor data over LoRa P2P.
void Logger::logLoRaMessages() {

  // Timer set to receive data.
  const unsigned long receivePeriod = 5000;
  const unsigned long ghostPeriod   = 1000;
  unsigned long receiveStartLoRa = millis();
  int receivedLines = 0;
  bool responseReceived = false;

  // Receives and logs data within the set period of time.
  // Will receive and log as much as 8 lines of data.
  while (millis() - receiveStartLoRa < receivePeriod && receivedLines < 8) {
    if (Serial1.available()) {
      responseReceived = true;
      String line = Serial1.readStringUntil('\n');
      line.trim();
      if (line.length() > 0) {
        appendFile(SD, DATA_LOG, line.c_str());
        Serial.print(F("LoRa logged: "));
        Serial.println(line);
        receivedLines++;
      }
    } else {
      if (!responseReceived && millis() - receiveStartLoRa > ghostPeriod) {
        Serial.println(F("Receive period skipped due to no LoRa responses."));
        break;
      }
    }
  }
  
  // The LoRa module is put to sleep.
  Serial1.println(F("AT+SLEEP=1"));
  delay(10);
}
